{
  "description": "Маркировка стального каната — российские ГОСТы (2688/3077/3083/7668/7669/7670/3066) и европейский EN 12385 / DIN 3060/3066. Извлекает диаметр, конструкцию, сердечник, тип контакта, стандарт, длину.",
  "source_field": "name",
  "priority": 100,
  "is_active": true,
  "rules": [
    {
      "parameter_slug": "diameter_mm",
      "patterns": [
        "(?:[øØ⌀∅]|диам(?:етр)?[\\.: ]?)\\s*(\\d{1,3}(?:[.,]\\d+)?)\\s*(?:мм|mm)\\b",
        "(?:[øØ⌀∅])\\s*(\\d{1,3}(?:[.,]\\d+)?)\\b",
        "(?:^|[^\\d.,])(\\d{1,2}(?:[.,]\\d+)?)\\s*(?:мм|mm)\\b(?![²a-zа-я])",
        "(?:^|\\s)[dD](\\d{1,3}(?:[.,]\\d+)?)(?:мм|mm)?\\b(?![\\wа-яА-Я])"
      ]
    },
    {
      "parameter_slug": "rope_construction",
      "patterns": [
        "(?:^|[^\\w])(\\d{1,2}\\s*×\\s*(?:[KW])?\\d{1,3}(?:WS|Seale|Warrington|Filler|[WSFK])?)(?=[^\\w]|$)"
      ]
    },
    {
      "parameter_slug": "rope_core",
      "patterns": [
        "\\b(EPIWRC|PWRC|IWRC|IWS|WSC)\\b",
        "\\b(NFC|FC)\\b",
        "\\bо\\.?\\s*с\\.?\\b",
        "\\bм\\.?\\s*с\\.?\\b",
        "органический\\s+сердечник",
        "металлический\\s+сердечник"
      ]
    },
    {
      "parameter_slug": "rope_lay_type",
      "patterns": [
        "\\b(ТЛК|ЛК[-‐]?(?:РО|Р|О)?|ТК)\\b"
      ]
    },
    {
      "parameter_slug": "gost_or_standard",
      "patterns": [
        "(ГОСТ\\s+\\d{3,5}(?:[-‐]\\d{2,4})?)",
        "(EN\\s+\\d{4,5}(?:[-‐]\\d{1,2})?)",
        "(DIN\\s+\\d{4,5}(?:[-‐]\\d{1,2})?)"
      ]
    },
    {
      "parameter_slug": "length_m",
      "patterns": [
        "(?:длин(?:а|ой)|length|L)[: =]?\\s*(\\d+(?:[.,]\\d+)?)\\s*(?:м|метр(?:а|ов)?|m)(?![²\\.\\wа-яА-Я])",
        "(?<=[\\s,;])(\\d{2,5}(?:[.,]\\d+)?)\\s*(?:м|метр(?:а|ов)?|m)(?![²\\.\\wа-яА-Я])"
      ]
    },
    {
      "parameter_slug": "wire_strength_n_mm2",
      "patterns": [
        "(\\d{4})\\s*(?:N/mm[²2]|Н/мм[²2]|MPa|МПа)",
        "(?:[-‐]|марк(?:ировочная)?\\.?\\s*групп(?:а)?\\s*)(\\d{4})(?![\\d])"
      ]
    },
    {
      "parameter_slug": "rope_series_name",
      "patterns": [
        "\\b(Powerlift\\s+Plus|Powerlift\\s+HT|Powerlift|Powerline|Powerflex|Powermax|Trustlift|Powerlift[-‐]?2K)\\b",
        "(?<=PAWO\\s)(F\\d{1,2}[A-Z]?)\\b",
        "(?<=Drako\\s)(\\d{3}[A-Z]?T?)\\b"
      ]
    },
    {
      "parameter_slug": "breaking_force_kn",
      "patterns": [
        "(\\d{1,4}(?:[.,]\\d+)?)\\s*(?:кН|kN)\\b"
      ]
    }
  ],
  "pre_normalize_rules": [
    {"from_regex": "(?<=\\d)\\s*[xXхХⅩ*]\\s*(?=\\d)", "to": "×"}
  ],
  "post_extract_rules": {
    "rope_core": {
      "type": "literal_map",
      "values": {
        "о.с.": "organic",
        "о.с": "organic",
        "ос": "organic",
        "о с": "organic",
        "органический сердечник": "organic",
        "FC": "organic",
        "NFC": "organic",
        "м.с.": "metallic",
        "м.с": "metallic",
        "мс": "metallic",
        "м с": "metallic",
        "металлический сердечник": "metallic",
        "IWRC": "metallic",
        "EPIWRC": "metallic",
        "PWRC": "metallic",
        "IWS": "metallic",
        "WSC": "metallic"
      }
    },
    "rope_lay_type": {
      "type": "literal_map",
      "values": {
        "ТК": "TK",
        "ЛК": "LK",
        "ЛК-Р": "LK",
        "ЛК-О": "LK",
        "ЛК-РО": "LK",
        "ЛКР": "LK",
        "ЛКО": "LK",
        "ЛКРО": "LK",
        "ТЛК": "TLK"
      }
    },
    "diameter_mm": {"type": "to_number"},
    "length_m": {"type": "to_number"},
    "wire_strength_n_mm2": {"type": "to_int"},
    "breaking_force_kn": {"type": "to_number"}
  },
