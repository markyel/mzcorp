APP_NAME=MyLift
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Database (PostgreSQL + pgvector) ===
# Локально / dev:        DB_HOST=nakoocirope.beget.app  DB_SSLMODE=require
# Prod (VPS Beget):      DB_HOST=10.19.0.2 (приватная сеть)  DB_SSLMODE=prefer
DB_CONNECTION=pgsql
DB_HOST=nakoocirope.beget.app
DB_PORT=5432
DB_DATABASE=MyLift
DB_USERNAME=myliftuser
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# === Yandex 360 OAuth (XOAUTH2 for IMAP/SMTP) ===
# Регистрируем приложение на https://oauth.yandex.ru/client/new.
# Redirect URI: https://mzcorp.ru/oauth/yandex/callback (или ${APP_URL}/oauth/yandex/callback в dev).
# Скоупы для MyLift: "mail:imap_full" + "mail:smtp".
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=
YANDEX_OAUTH_SCOPE="mail:imap_full mail:smtp"

# === OpenAI (AI-классификация писем, KB, эмбеддинги) ===
# Для России — может потребоваться reverse-proxy:
#   OPENAI_BASE_URL=https://your-proxy.example.com
#   OPENAI_PROXY_KEY=secret
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_PROXY_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAIL_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_PARSING_MODEL=gpt-4.1
OPENAI_VISION_MODEL=gpt-4o
# Phase 1.8c: расширенный классификатор (LazyLift drop-in)
OPENAI_CATEGORY_MODEL=gpt-4o
