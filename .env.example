APP_NAME=MyLift
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Database (PostgreSQL + pgvector) ===
# Локально / dev:        DB_HOST=nakoocirope.beget.app  DB_SSLMODE=require
# Prod (VPS Beget):      DB_HOST=10.19.0.2 (приватная сеть)  DB_SSLMODE=prefer
DB_CONNECTION=pgsql
DB_HOST=nakoocirope.beget.app
DB_PORT=5432
DB_DATABASE=MyLift
DB_USERNAME=myliftuser
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# === Support / «связь с создателем» ===
# Адрес разработчика, на который улетают уведомления о новых тикетах
# и ответах пользователей. Пусто → письма не шлются, тикет видно в /support.
SUPPORT_DEVELOPER_EMAIL=
# Имя для подписи в footer'е модалки: «Отвечает {имя}, обычно в течение дня».
# Пусто → подпись скрыта.
SUPPORT_DEVELOPER_NAME=
# «Тихое окно» email-дайджеста ответов по тикетам (минуты): письмо уходит,
# когда после последнего нового ответа прошло N минут (серия → одно письмо).
SUPPORT_DIGEST_QUIET_MINUTES=5

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# === Yandex 360 OAuth (XOAUTH2 for IMAP/SMTP) ===
# Регистрируем приложение на https://oauth.yandex.ru/client/new.
# Redirect URI: https://mzcorp.ru/oauth/yandex/callback (или ${APP_URL}/oauth/yandex/callback в dev).
# Скоупы для MyLift: "mail:imap_full" + "mail:smtp".
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=
YANDEX_OAUTH_REDIRECT_URI=
YANDEX_OAUTH_SCOPE="mail:imap_full mail:smtp"

# === OpenAI (AI-классификация писем, KB, эмбеддинги) ===
# Для России — может потребоваться reverse-proxy:
#   OPENAI_BASE_URL=https://your-proxy.example.com
#   OPENAI_PROXY_KEY=secret
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_PROXY_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAIL_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_PARSING_MODEL=gpt-4.1
OPENAI_VISION_MODEL=gpt-4o
# Phase 1.8c: расширенный классификатор (LazyLift drop-in)
OPENAI_CATEGORY_MODEL=gpt-4o
# Классификатор релевантности тяжёлых вложений + финальный консолидатор позиций
# split-пути (RequestItemParsingService). Дефолты включены.
OPENAI_ATTACHMENT_RELEVANCE_MODEL=gpt-4o-mini
OPENAI_ATTACHMENT_RELEVANCE_ENABLED=true
OPENAI_CONSOLIDATION_ENABLED=true

# Phase 1.8d+: веб-фетч URL'ов из тела входящих писем
# (RequestItemParsingService → InboundUrlFetcherService).
# Все настройки опциональны — дефолты в config/services.php.
WEB_FETCH_ENABLED=true
WEB_FETCH_MAX_URLS_PER_EMAIL=10
WEB_FETCH_URL_TIMEOUT=10
WEB_FETCH_BUDGET_SECONDS=60
WEB_FETCH_MAX_SIZE_BYTES=2097152
WEB_FETCH_MAX_TEXT_CHARS=8000
WEB_FETCH_CACHE_TTL_DAYS=7
WEB_FETCH_USER_AGENT="MyLift-Bot/1.0 (+https://mzcorp.ru)"

# Phase 2: приёмник snapshot'ов корпоративного каталога (POST /api/catalog/import).
# Если токен пуст — endpoint отдаёт 503 (security default).
# На проде ставить длинный random — например `openssl rand -hex 32`.
CATALOG_IMPORT_TOKEN=
CATALOG_IMPORT_MAX_ROWS=50000
# Защита от случайного обнуления каталога: mode=full snapshot с rows < этого
# значения отвергается 422. Дефолт 1 (запрет только пустого payload'а).
# После первой нормальной выгрузки имеет смысл повысить до ~80% от ожидаемого
# размера каталога, чтобы битая частичная выгрузка не схлопывала строки.
CATALOG_IMPORT_MIN_FULL_ROWS=1

# Ставка НДС в процентах для расчёта итога по каталожным ценам в карточке
# заявки. 2019-2026: 20; с 2026: 22. Поддерживает дробные значения.
VAT_PERCENT=22

# Phase 2 use-case C: семантический match каталога по name через pgvector.
# Порог cosine similarity (0..1): меньше → больше ложно-положительных,
# больше → теряем валидные матчи. После накопления данных подкрутим
# (потом переедет в UI «Настройки»).
CATALOG_NAME_MATCH_ENABLED=true
CATALOG_NAME_MATCH_THRESHOLD=0.75
# High-confidence порог: similarity >= → LLM-валидацию пропускаем (вектор
# и так уверен). Диапазон [threshold, hc_threshold) → mini-LLM проверяет
# «один ли это товар» (звено≠звезда, поручень≠ролик и т.п.).
CATALOG_NAME_MATCH_HC_THRESHOLD=0.90
# Killswitch для LLM-валидации (на случай OpenAI rate limit / экономии).
CATALOG_NAME_MATCH_LLM_VALIDATION_ENABLED=true
# Что делать если LLM-вызов упал (прокси 503 и т.п.):
#   reject (default) — match отклоняем, precision приоритет;
#   accept           — принимаем без проверки, recall приоритет.
CATALOG_NAME_MATCH_LLM_FAIL_ACTION=reject
# Размер батча на /v1/embeddings (1..2048). 100 — компромисс latency/HTTP.
OPENAI_EMBEDDING_BATCH_SIZE=100

# Circuit-breaker для OpenAI-вызовов (категоризатор писем). При N подряд
# transient-ошибок (429 insufficient_quota / 503 / 502 / timeout) категоризатор
# отключается на cooldown_minutes — не жечь лишние списания + bell-нотификация
# админу с ссылкой на платёжку. Первый успешный вызов после паузы — автоснятие.
OPENAI_CB_FAIL_THRESHOLD=3
OPENAI_CB_COOLDOWN_MINUTES=15
OPENAI_CB_NOTIFY_COOLDOWN_MINUTES=60
